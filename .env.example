# ============================================================================
# OUTLOOK/MICROSOFT 365 CONFIGURATION
# ============================================================================

# Your Outlook/Office 365 email address
OUTLOOK_EMAIL=your-email@outlook.com

# Your Outlook password
# NOTE: For Office 365, use an "App Password" instead of your regular password
# How to create App Password:
# 1. Go to https://account.microsoft.com/account/manage-my-microsoft-account
# 2. Select "Security" on the left sidebar
# 3. Go to "Advanced security options"
# 4. Click "App passwords"
# 5. Select "Mail" and "Windows" (or your device)
# 6. Copy the generated password and paste it here
OUTLOOK_PASSWORD=your-app-password-here


# ============================================================================
# MYSQL DATABASE CONFIGURATION
# ============================================================================

# MySQL host (localhost if running locally, IP/domain if remote)
MYSQL_HOST=localhost

# MySQL username
MYSQL_USER=root

# MySQL password
MYSQL_PASSWORD=your-mysql-password

# MySQL database name (must exist)
MYSQL_DATABASE=your_database_name

# MySQL port (default is 3306)
MYSQL_PORT=3306

# Table name to insert data into (table must exist)
# The script will NOT create the table automatically
TABLE_NAME=excel_data


# ============================================================================
# EMAIL NOTIFICATION CONFIGURATION (Optional)
# ============================================================================

# Email address to receive notification reports
# Leave blank to disable notifications
NOTIFY_EMAIL=your-notification-email@gmail.com

# Send notification on successful execution (True/False)
NOTIFY_ON_SUCCESS=True

# Send notification on errors (True/False)
NOTIFY_ON_ERROR=True


# ============================================================================
# AUTOMATION SETTINGS
# ============================================================================

# How many days back to search for emails (default: 1)
DAYS_BACK=1

# Directory to store temporary downloaded files
TEMP_DIR=./temp_files

# Maximum number of retries for connections
MAX_RETRIES=3

# Delay between retries in seconds
RETRY_DELAY=5
